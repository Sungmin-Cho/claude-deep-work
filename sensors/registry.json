{
  "$schema": "sensor-registry-v2",
  "$comment": "Structured, shell-free ecosystem sensor definitions.",
  "ecosystems": {
    "javascript": {
      "detect": { "any_of": ["package.json"] },
      "file_extensions": [".js", ".jsx", ".mjs", ".cjs"],
      "lint": { "processSpec": { "kind": "node-package-bin", "package": "eslint", "bin": "eslint", "args": ["--format", "json", "."] }, "parser": "eslint", "budgetMs": 30000 },
      "typecheck": null,
      "coverage_flag": ["--coverage", "--json"],
      "mutation": { "processSpec": { "kind": "node-package-bin", "package": "@stryker-mutator/core", "bin": "stryker", "args": ["run"] }, "parser": "stryker", "budgetMs": 300000, "maxMutants": 200 }
    },
    "typescript": {
      "detect": { "require": ["tsconfig.json"], "any_of": ["package.json"] },
      "file_extensions": [".ts", ".tsx"],
      "lint": { "processSpec": { "kind": "node-package-bin", "package": "eslint", "bin": "eslint", "args": ["--format", "json", "."] }, "parser": "eslint", "budgetMs": 30000 },
      "typecheck": { "processSpec": { "kind": "node-package-bin", "package": "typescript", "bin": "tsc", "args": ["--noEmit"] }, "parser": "tsc", "budgetMs": 60000 },
      "coverage_flag": ["--coverage", "--json"],
      "mutation": { "processSpec": { "kind": "node-package-bin", "package": "@stryker-mutator/core", "bin": "stryker", "args": ["run"] }, "parser": "stryker", "budgetMs": 300000, "maxMutants": 200 }
    },
    "python": {
      "detect": { "any_of": ["pyproject.toml", "setup.py", "requirements.txt"] },
      "file_extensions": [".py"],
      "lint": { "processSpec": { "kind": "native-executable", "executable": "ruff", "args": ["check", "--output-format", "json", "."] }, "parser": "ruff", "budgetMs": 30000 },
      "typecheck": { "processSpec": { "kind": "native-executable", "executable": "mypy", "args": ["--no-error-summary", "."] }, "parser": "generic-line", "budgetMs": 60000 },
      "coverage_flag": ["--cov", "--cov-report=json"],
      "mutation": { "processSpec": { "kind": "native-executable", "executable": "mutmut", "args": ["run"] }, "parser": "generic-line", "budgetMs": 600000, "maxMutants": 150 }
    },
    "csharp": {
      "detect": { "any_of": ["*.csproj", "*.sln"] },
      "file_extensions": [".cs"],
      "lint": { "processSpec": { "kind": "native-executable", "executable": "dotnet", "args": ["format", "--verify-no-changes"] }, "parser": "generic-line", "budgetMs": 30000 },
      "typecheck": { "processSpec": { "kind": "native-executable", "executable": "dotnet", "args": ["build", "--no-restore", "--nologo"] }, "parser": "generic-line", "budgetMs": 60000 },
      "coverage_flag": ["--collect:XPlat Code Coverage"],
      "mutation": { "processSpec": { "kind": "native-executable", "executable": "dotnet", "args": ["stryker"] }, "parser": "stryker", "budgetMs": 600000, "maxMutants": 200 }
    },
    "cpp": {
      "detect": { "any_of": ["CMakeLists.txt"] },
      "file_extensions": [".cpp", ".cc", ".cxx", ".h", ".hpp"],
      "lint": { "processSpec": { "kind": "native-executable", "executable": "clang-tidy", "args": [] }, "parser": "clang-tidy", "budgetMs": 30000 },
      "typecheck": { "processSpec": { "kind": "native-executable", "executable": "cmake", "args": ["--build", ".", "--target", "all"] }, "parser": "generic-line", "budgetMs": 60000 },
      "coverage_flag": null,
      "mutation": { "processSpec": { "kind": "native-executable", "executable": "mull-runner", "args": [] }, "parser": "generic-line", "budgetMs": 600000, "maxMutants": 100 }
    }
  }
}
